# wrangler.toml.example
#
# Copy this file to wrangler.toml and fill in your values.

# Usage:
#   cp wrangler.toml.example wrangler.toml
#   # edit wrangler.toml with your settings
#   wrangler dev           # local dev on http://localhost:8787
#   wrangler deploy        # deploy to Cloudflare Workers

# Only for development, manual deployment, and CI pipeline.
# The name, compatibility_date, and main fields are ignored in action.yml.
name = "autodiscover-email-settings"
compatibility_date = "2026-04-12"
main = "src/index.ts"

[vars]
# ── General ──────────────────────────────────────────────────────────────────

# Display name shown in autodiscover responses and the support page.
COMPANY_NAME = "Example Corp"

# URL of this autodiscover service — shown in autodiscover responses.
SUPPORT_URL = "https://autodiscover.example.com"

# The email domain this service configures. Must match your MX records.
DOMAIN = "example.com"

# ── IMAP ─────────────────────────────────────────────────────────────────────
# Leave IMAP_HOST empty to disable IMAP in all responses.
# IMAP_SOCKET: SSL | STARTTLS | None
#   SSL      — implicit TLS; use with port 993
#   STARTTLS — explicit TLS upgrade; use with port 143
#   None     — plaintext (not recommended)

IMAP_HOST   = "imap.example.com"
IMAP_PORT   = "993"
IMAP_SOCKET = "SSL"

# ── POP3 ─────────────────────────────────────────────────────────────────────
# Leave POP_HOST empty to disable POP3 in all responses.
# POP_SOCKET: SSL | STARTTLS | None
#   SSL      — implicit TLS; use with port 995
#   STARTTLS — explicit TLS upgrade; use with port 110

POP_HOST   = "pop3.example.com"
POP_PORT   = "995"
POP_SOCKET = "SSL"

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable SMTP in all responses.
# SMTP_SOCKET: SSL | STARTTLS | None
#   STARTTLS — explicit TLS upgrade; use with port 587 (recommended)
#   SSL      — implicit TLS; use with port 465

SMTP_HOST   = "smtp.example.com"
SMTP_PORT   = "587"
SMTP_SOCKET = "STARTTLS"

# ── ActiveSync / MobileSync ──────────────────────────────────────────────────
# Leave MOBILESYNC_URL empty to omit the MobileSync block from Autodiscover
# responses. Used by Outlook for Exchange ActiveSync autodiscovery.

MOBILESYNC_URL  = "https://sync.example.com"
MOBILESYNC_NAME = "sync.example.com"

# ── LDAP ─────────────────────────────────────────────────────────────────────
# Leave LDAP_HOST empty to omit the LDAP block from Apple mobileconfig profiles.

LDAP_HOST="ldap.example.com"
LDAP_PORT="636"
LDAP_SOCKET="SSL"
LDAP_BASE="dc=ldap,dc=example,dc=com"
LDAP_USER_FIELD="uid"
LDAP_USER_BASE="ou=People,dc=ldap,dc=example,dc=com"
LDAP_SEARCH="(|(objectClass=PostfixBookMailAccount))"

# ── Apple mobileconfig ───────────────────────────────────────────────────────
# Leave PROFILE_IDENTIFIER empty to disable the /email.mobileconfig endpoint.
#
# PROFILE_IDENTIFIER — reverse-DNS string identifying this profile.
#   Example: com.example.autodiscover
#
# PROFILE_UUID / MAIL_UUID / LDAP_UUID — must be unique UUIDs per deployment.
#   Generate with: uuidgen

PROFILE_IDENTIFIER = "com.example.autodiscover"
PROFILE_UUID       = "92943D26-CAB3-4086-897D-DC6C0D8B1E86"
MAIL_UUID          = "7A981A9E-D5D0-4EF8-87FE-39FD6A506FAC"
LDAP_UUID          = "6ECB6BA9-2208-4ABF-9E60-4E9F4CD7309E"
